# GoldasT Bot v2 - Environment Variables
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# NEVER commit .env to git - it contains sensitive credentials

# ===============================================
# BITUNIX API CREDENTIALS (REQUIRED)
# ===============================================
# Get these from: https://www.bitunix.com/futures/account/api-management
BITUNIX_API_KEY=your_api_key_here
BITUNIX_SECRET=your_api_secret_here

# ===============================================
# TELEGRAM BOT CONFIGURATION (OPTIONAL)
# ===============================================
# Get token from: https://t.me/botfather
# Get your user ID from: https://t.me/userinfobot
# 
# Steps to setup Telegram:
# 1. Search for @BotFather on Telegram and send /newbot
# 2. Follow instructions to create your bot
# 3. Copy the bot token (looks like: 123456:ABC-DEF...)
# 4. Search for @userinfobot and send /start to get your user ID
# 5. Add token and user ID below
#
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_ID=
# For multiple users, separate with commas: 123456789,987654321
TELEGRAM_ALLOWED_USERS=

# ===============================================
# LOGGING (OPTIONAL)
# ===============================================
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ===============================================
# DOCKER-SPECIFIC (OPTIONAL)
# ===============================================
PYTHONUNBUFFERED=1
TZ=America/New_York
ENVIRONMENT=production
